    { "name": "History", "short_name": "History", "url": "/#history", "description": "Historical trends & session archive" },
    { "name": "Guild of Agents (RPG)", "short_name": "RPG", "url": "/#rpg", "description": "RPG quest-world visualization of your agents" }
